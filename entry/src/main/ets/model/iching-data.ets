// Yao position analysis: 六爻位分阴阳
// Positions 1(初),3,5 are yang positions; 2,4,6(上) are yin positions
// Yang line (1) in yang position = 得位 (proper)
// Yin line (0) in yin position = 得位
// Also: position 2 and 5 are central (得中) - 2 is center of lower, 5 is center of upper
function analyzeYaoPosition(lineIdx: number, bit: string): string {
  const pos = lineIdx + 1 // 1-based
  const isYang = bit === '1'
  const isYangPos = pos === 1 || pos === 3 || pos === 5
  const isCenter = pos === 2 || pos === 5
  const parts: string[] = []
  if (isCenter) parts.push('得中：居卦之中，行中正之道')
  if ((isYang && isYangPos) || (!isYang && !isYangPos)) {
    parts.push('得位：阴阳当位，名正言顺')
  } else {
    parts.push('失位：阴阳不当位，需谨慎调整')
  }
  // Corresponding check: 初↔四, 二↔五, 三↔上
  // Can't do cross-line check here, so just basic analysis
  return parts.join('；')
}

