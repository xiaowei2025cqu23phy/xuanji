const HEXAGRAMS_DATA: Map<string, HexEntry> = buildHexagramData()

// ================================================================
// Hexagram lookup
// ================================================================
export function GET_HEX_BY_BINARY(bin: string): Hexagram {
  const data = HEXAGRAMS_DATA.get(bin)
  if (!data) {
    return { id: bin, name: '未名卦', pinyin: '', symbol: '?', binary: bin, judgement: '古籍不详', meaning: '未知之象', number: 0 }
  }
  return {
    id: bin, binary: bin,
    name: data.name, pinyin: data.pinyin, symbol: data.symbol,
    judgement: data.judgement, meaning: data.meaning, number: data.number,
    lines: data.lines, tuanZhuan: data.tuanZhuan, daXiang: data.daXiang, xuGua: data.xuGua
  }
}

// ================================================================
// Line detail builder — enriched with 小象 and 爻位分析
// ================================================================
export function getLineDetails(hex: Hexagram, movingIndexes?: number[]): LineDetail[] {
  const data = HEXAGRAMS_DATA.get(hex.binary)
  if (!data || !data.lines || data.lines.length === 0) return []

  const bottomTrigram = hex.binary.slice(0, 3)
  const topTrigram = hex.binary.slice(3, 6)
  const posNames = ['初', '二', '三', '四', '五', '上']

  // Qian-specific historical allusions
  const qianAllusions: string[] = []
  if (hex.number === 1) {
    qianAllusions[0] = '舜耕历山，历经磨难而终得圣治。乾卦之始，纯阳之气尚在潜伏。'
    qianAllusions[1] = '孔子游学列国，初展才华。名声渐起，进入社会视野。'
    qianAllusions[2] = '周文王在羑里演易。虽处危境，以忧患意识自励。'
    qianAllusions[3] = '子牙垂钓渭水，意在江山。进退自如，不以得失乱心。'
    qianAllusions[4] = '汉高祖入关，众望所归。得时得位，大展宏图。'
    qianAllusions[5] = '西楚霸王乌江自刎。盛极必衰，刚愎自用之诫。'
  }

  const lines = data.lines
  const xiaoXiang = data.xiaoXiang
  const details: LineDetail[] = []

  for (let i = 0; i < lines.length; i++) {
    const lineBit = hex.binary[i] // '1' for yang, '0' for yin
    const isUpper = i >= 3
    const trigramBin = isUpper ? topTrigram : bottomTrigram
    const meta = BAGUA_META.get(trigramBin)

    // Allusion
    const allusion = (i < qianAllusions.length && qianAllusions[i])
      ? qianAllusions[i]
      : '此爻见于《易经》' + hex.name + '卦，' + GENERIC_ALLUSION

    // 爻位分析
    const yaoWei = analyzeYaoPosition(i, lineBit)

    // Build analysis text based on line nature
    let analysis = data.meaning.split('。')[0] + '。'
    const isMoving = movingIndexes && movingIndexes.indexOf(i) >= 0
    if (isMoving) {
      analysis += ' 此爻发动，预示能量正在转换，是该卦的关键变数所在。'
    } else {
      analysis += ' 此爻安静，代表格局中的稳定因素。'
    }

    const detail: LineDetail = {
      text: lines[i],
      allusion: allusion,
      analysis: analysis,
      positionContext: POSITION_SENSE[i],
      hexRelationship: '作为' + hex.name + '卦（' + hex.meaning.split('。')[0] + '）的' + posNames[i] + '爻。',
      yaoWei: yaoWei
    }

    if (meta) {
      detail.preBagua = '先天位：' + meta.pre + ' | ' + meta.symb
      detail.postBagua = '后天位：' + meta.post + ' | 该爻所属卦象正发生时位转化。'
    }

    // 小象传
    if (xiaoXiang && i < xiaoXiang.length) {
      detail.xiaoXiang = xiaoXiang[i]
    }

    details.push(detail)
  }

  return details
}

// ================================================================
// Hexagram transformations
// ================================================================
export function getMutualHexagram(bin: string): string {
  const lines = bin.split('')
  return lines[1] + lines[2] + lines[3] + lines[2] + lines[3] + lines[4]
}

export function getChangedHexagram(bin: string, movingIndexes: number[]): string {
  const lines = bin.split('')
  for (const idx of movingIndexes) { lines[idx] = lines[idx] === '1' ? '0' : '1' }
  return lines.join('')
}

export function getOppositeHexagram(bin: string): string {
  return bin.split('').map(c => c === '1' ? '0' : '1').join('')
}

export function getInverseHexagram(bin: string): string {
  return bin.split('').reverse().join('')
}

// ================================================================
// TiYong (体用) calculation
// ================================================================
export interface TiYongResult {
  ti: string; yong: string; tiElement: string; yongElement: string
  relative: string; relation: string; description: string
}

interface TiYongLabelResult { label: string; desc: string }

function tiYongLabel(qSelf: string, pOther: string, rel: ElementRelation): TiYongLabelResult {
  if (rel.label === '比和') return { label: '比和 (吉)', desc: qSelf + '见' + pOther + '，' + rel.desc }
  if (rel.label === '我克') return { label: '体克用 (小吉)', desc: qSelf + '克' + pOther + '，' + rel.desc }
  if (rel.label === '我生') return { label: '体生用 (中吉)', desc: qSelf + '生' + pOther + '，' + rel.desc }
  if (rel.label === '克我') return { label: '用克体 (凶)', desc: pOther + '克' + qSelf + '，' + rel.desc }
  if (rel.label === '生我') return { label: '用生体 (大吉)', desc: pOther + '生' + qSelf + '，' + rel.desc }
  return { label: '平平', desc: '五行气息平和。' }
}

export function getTiYong(bin: string, movingLineIdx: number | null): TiYongResult {
  if (movingLineIdx === null) {
    return { ti: '无', yong: '无', tiElement: '无', yongElement: '无', relative: '无', relation: '无动爻', description: '无动爻不分体用。点击任意一爻设为动爻可看体用关系。' }
  }
  const bottom = bin.slice(0, 3)
  const top = bin.slice(3, 6)
  const isTopYong = movingLineIdx >= 3
  const tiBin = isTopYong ? bottom : top
  const yongBin = isTopYong ? top : bottom
  const ti = TRIGRAMS.get(tiBin)
  const yong = TRIGRAMS.get(yongBin)
  if (!ti || !yong) {
    return { ti: '', yong: '', tiElement: '', yongElement: '', relative: '', relation: '', description: '' }
  }
  const rel = getElementRelation(ti.element, yong.element)
  const tl = tiYongLabel(ti.element, yong.element, rel)
  return {
    ti: ti.name, yong: yong.name,
    tiElement: ti.element, yongElement: yong.element,
    relative: rel.relative, relation: tl.label, description: tl.desc
  }
}

// ================================================================
// Export for search
// ================================================================
export function getTrigramBreakdown(bin: string): string {
  const lowerBin = bin.slice(0, 3)
  const upperBin = bin.slice(3, 6)
  return trigramAnalysis(lowerBin, upperBin)
}
