// ================================================================
// Upper/lower trigram analysis helper
// ================================================================
function trigramAnalysis(lowerBin: string, upperBin: string): string {
  const lowerT = TRIGRAMS.get(lowerBin)
  const upperT = TRIGRAMS.get(upperBin)
  if (!lowerT || !upperT) return ''
  const rel = getElementRelation(lowerT.element, upperT.element)
  let text = '下卦' + lowerT.name + '（' + lowerT.nature + '/' + lowerT.element + '），'
  text += '上卦' + upperT.name + '（' + upperT.nature + '/' + upperT.element + '）。'
  text += '上下关系：' + rel.label + '（' + rel.desc + '）'
  return text
}

